<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1565C0"
    tools:context=".Registro">



    <TextView
        android:id="@+id/textView2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:textSize="30sp"
        android:textAlignment="center"
        android:text="Registro de Conductor"
        android:textColor="#FCFCFF"
        android:textStyle="bold"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="30dp"
        android:background="@drawable/custom_editex"
        app:cardCornerRadius="20dp"
        app:cardElevation="20dp">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_gravity="center_horizontal"
            android:padding="24dp"
            >



            <EditText
                android:id="@+id/txtPlaca"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Placa:"
                android:background="@drawable/custom_editex"
                android:textSize="20sp"
                android:minHeight="40dp"
                android:padding="12dp"
                android:drawablePadding="8dp"
                android:inputType="textPersonName"
                android:layout_marginTop="20dp"/>

            <EditText
                android:id="@+id/txtMarca"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Marca del vehículo:"
                android:background="@drawable/custom_editex"
                android:textSize="20sp"
                android:drawablePadding="8dp"
                android:minHeight="40dp"
                android:padding="12dp"
                android:inputType="text"
                android:layout_marginTop="20dp"/>
            <EditText
                android:id="@+id/txtModelo"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Modelo:"
                android:background="@drawable/custom_editex"
                android:textSize="20sp"
                android:minHeight="40dp"
                android:drawablePadding="8dp"
                android:padding="12dp"
                android:inputType="text"
                android:layout_marginTop="20dp"/>

            <EditText
                android:id="@+id/txtColor"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Color:"
                android:background="@drawable/custom_editex"
                android:textSize="20sp"
                android:minHeight="40dp"
                android:drawablePadding="8dp"
                android:padding="12dp"
                android:inputType="text"
                android:layout_marginTop="20dp"/>

            <Button
                android:id="@+id/btnDatos"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="20dp"
                android:text="Guardar Datos"
                android:textSize="20sp"
                app:cornerRadius="15dp"
                android:backgroundTint="#0505A0"/>


            <Button
                android:id="@+id/btnIngresar"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="20dp"
                android:text="Ingresar"
                android:textSize="18sp"
                app:cornerRadius="15dp"
                android:backgroundTint="#EB1708"/>

            <Button
                android:id="@+id/btnVolver"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:textSize="18sp"
                app:cornerRadius="15dp"
                android:layout_marginTop="20dp"
                android:text="Volver"/>




        </LinearLayout>



    </androidx.cardview.widget.CardView>


</LinearLayout>